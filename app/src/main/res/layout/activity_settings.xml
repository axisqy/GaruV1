<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <Button
        android:id="@+id/btn_download_model"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Download Model" />

    <ProgressBar
        android:id="@+id/model_progress_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="?android:attr/progressBarStyleHorizontal" />

    <TextView
        android:id="@+id/tv_model_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Model status" />

    <TextView
        android:id="@+id/tv_model_status_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Not downloaded" />

    <EditText
        android:id="@+id/et_system_prompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="System prompt" />

    <Button
        android:id="@+id/btn_save_rules"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save Rules" />

    <Button
        android:id="@+id/btn_clear_history"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Clear Conversation History" />

</LinearLayout>
    <Button
        android:id="@+id/btn_save_rules"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save Rules" />

</LinearLayout>
